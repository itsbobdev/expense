# Copy this file to backend/.env for local development.

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Database Configuration
# For SQLite (development). Relative SQLite paths resolve from backend/.
DATABASE_URL=sqlite:///./expense_tracker.db

# For PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost/expense_tracker

# Application Configuration
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG=False

# File Storage
UPLOAD_DIR=./uploads
ML_MODEL_DIR=./ml_models

# ML Configuration
ML_CONFIDENCE_THRESHOLD_AUTO=0.95
ML_CONFIDENCE_THRESHOLD_SUGGEST=0.50
ML_MIN_TRAINING_SAMPLES=50
ML_RETRAIN_INTERVAL=10

# Google Sheets bill export
GOOGLE_SHEETS_BILL_EXPORT_ENABLED=False
GOOGLE_SHEETS_BILL_EXPORT_SPREADSHEET=https://docs.google.com/spreadsheets/d/1KeUy6IAZFrXpdrEwfGwlt9pSzaIDW9DHEvGyD5Z1vRw/edit?usp=sharing
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
